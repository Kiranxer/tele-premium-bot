# 🤖 Telegram Bot
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# 🌐 Webhook URL (Koyeb app URL ONLY)
WEBHOOK_URL=https://your-app-name.koyeb.app

# 🗄️ Database
